{
  "name": "vallium",
  "version": "0.1.1",
  "description": "Vallium is a simple utility and ui framework for React.",
  "keywords": [
    "react",
    "ui",
    "framework",
    "utility",
    "typescript",
    "vallium"
  ],
  "author": "Christopher Brandt",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepack": "json -f package.json -I -e \"delete this.devDependencies; delete this.dependencies\""
  },
  "peerDependencies": {},
  "files": [
    "dist"
  ],
  "main": "./dist/vallium.umd.js",
  "module": "./dist/vallium.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vallium.es.js",
      "require": "./dist/vallium.umd.js"
    }
  }
}
